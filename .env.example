# AI provider configuration. Leave API keys empty until you enable AI reports.
AI_ENABLED=false
AI_PROVIDER=deepseek
AI_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Local runtime settings. Paths are resolved from the project root by shared helpers.
DATABASE_PATH=data/a_stock_research.sqlite
REPORTS_PATH=reports
LOGS_PATH=data/logs
RAW_DATA_PATH=data/raw
CACHE_PATH=data/cache

# Web settings.
NEXT_PUBLIC_APP_NAME=InvestPilot
